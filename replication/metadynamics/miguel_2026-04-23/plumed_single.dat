# [DEPRECATED 2026-04-25 — pre-FP-034 path; do NOT relaunch with this file]
#
# Original purpose: Miguel fallback contract (HEIGHT=0.3, BIASFACTOR=15)
# on the OLD naive-mapping path (REFERENCE=path_gromacs.pdb), with
# λ=3.77 Å⁻² derived from the OLD path's ⟨MSD⟩.
#
# Why deprecated:
#   1. path_gromacs.pdb itself was invalidated by FP-034 (cross-species
#      Pf vs St residue mismatch, +5 offset); replaced by
#      replication/metadynamics/path_seqaligned/path_seqaligned_gromacs.pdb.
#   2. λ=3.77 was computed on the OLD path's ⟨MSD⟩; on the new
#      seq-aligned path the SI-faithful Branduardi value is 100.79 Å⁻².
#
# Live single-walker fallback (post-FP-034, post-SI-audit):
#   replication/metadynamics/path_seqaligned/plumed.dat
#
# This file is preserved for FP-034 / FP-027 / FP-022 audit traceability.

UNITS LENGTH=A ENERGY=kcal/mol

# No RESTART on fresh launch (FP-033); add back only when resuming.

WHOLEMOLECULES ENTITY0=1-39268

p1: PATHMSD REFERENCE=path_gromacs.pdb LAMBDA=3.77 NEIGH_STRIDE=100 NEIGH_SIZE=6

METAD ARG=p1.sss,p1.zzz ADAPTIVE=DIFF SIGMA=1000 SIGMA_MIN=0.1,0.01 HEIGHT=0.3 PACE=1000 BIASFACTOR=15.0 TEMP=350.0 GRID_MIN=0.5,0.0 GRID_MAX=15.5,2.8 GRID_BIN=300,100

UPPER_WALLS ARG=p1.zzz AT=2.5 KAPPA=800 LABEL=uwall

PRINT ARG=* STRIDE=100 FILE=COLVAR FMT=%8.4f
